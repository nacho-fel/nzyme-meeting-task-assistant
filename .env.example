# Optional LLM integration. Leave blank to use deterministic local fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Notion integration. Keep dry-run true for local-only execution.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DRY_RUN=false (true if not connected to Notion yet)

# Local configuration.
DATA_DIR=./data
LOG_LEVEL=INFO
